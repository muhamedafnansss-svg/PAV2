# VAL Environment Configuration — 10 GB Memory-Safe Edition
# ===========================================================
# Copy to .env before running:  copy .env.example .env
# NEVER commit .env to version control.
#
# MEMORY BUDGET (RAM + VRAM combined must stay under 10 GB):
# ┌─────────────────────────────────────────────┐
# │ Component    │ Budget                        │
# ├─────────────────────────────────────────────┤
# │ Model VRAM   │ max 5 GB  (one at a time)    │
# │ System RAM   │ max 5 GB                     │
# │ Context      │ max 1500 tokens              │
# │ Logs         │ max 2 MB per file, 3 days    │
# └─────────────────────────────────────────────┘
# Model VRAM estimate (4-bit):
#   TinyLLaMA  → ~0.8 GB  ← DEFAULT (lowest footprint)
#   Gemma 2B   → ~1.5 GB  ← raised on demand
#   Mistral 7B → ~4.5 GB  ← only for complex queries

# ─── Memory Ceiling ───────────────────────────────────────────────────────────
VAL_MAX_MEMORY_GB=10.0
# Dynamic downgrade thresholds (see router.py):
#   total > 8 GB → force TinyLLaMA
#   total > 6 GB → force Gemma

# ─── Device ───────────────────────────────────────────────────────────────────
# cuda = GPU (recommended). auto = detect. cpu = CPU only (very slow).
VAL_DEVICE=cuda

# ─── Default Model ────────────────────────────────────────────────────────────
# TinyLLaMA is default — handles most queries with <1 GB VRAM.
# Router auto-upgrades to Gemma/Mistral based on query complexity.
VAL_DEFAULT_MODEL=tinyllama

# ─── Background Agents ────────────────────────────────────────────────────────
# KEEP FALSE — background agents use extra RAM threads.
VAL_BACKGROUND_AGENTS=false

# ─── Mistral 7B (Complex Reasoning Only) ─────────────────────────────────────
# 4-bit = ~4.5 GB VRAM. Only loaded on complex queries, unloaded immediately after.
MISTRAL_ENABLED=true
MISTRAL_MAX_TOKENS=512
MISTRAL_TEMPERATURE=0.7
MISTRAL_TOP_P=0.9
MISTRAL_CONTEXT_LEN=1500
MISTRAL_4BIT=true
MISTRAL_8BIT=false

# ─── Gemma 2B (General Tasks) ─────────────────────────────────────────────────
# 4-bit = ~1.5 GB VRAM. Used when TinyLLaMA isn't enough.
GEMMA_ENABLED=true
GEMMA_MAX_TOKENS=512
GEMMA_TEMPERATURE=0.7
GEMMA_TOP_P=0.9
GEMMA_CONTEXT_LEN=1500
GEMMA_4BIT=true
GEMMA_8BIT=false

# ─── TinyLLaMA (DEFAULT — Fast Utility) ──────────────────────────────────────
# 4-bit = ~0.8 GB VRAM. Default model for all short/simple queries.
TINYLLAMA_ENABLED=true
TINYLLAMA_MAX_TOKENS=256
TINYLLAMA_TEMPERATURE=0.6
TINYLLAMA_TOP_P=0.9
TINYLLAMA_CONTEXT_LEN=1500
TINYLLAMA_4BIT=true
TINYLLAMA_8BIT=false

# ─── Security ─────────────────────────────────────────────────────────────────
VAL_ALLOW_SHELL=false
VAL_SHELL_ALLOWLIST=
VAL_ALLOW_NETWORK=false
VAL_ALLOW_FILE_WRITE=true
VAL_FILE_WRITE_DIR=
VAL_MAX_PROMPT_LEN=4096
VAL_RATE_LIMIT=30
VAL_SANDBOX=true

# ─── Logging (Strict Size Limits) ────────────────────────────────────────────
VAL_LOG_LEVEL=INFO
VAL_LOG_JSONL=true
VAL_LOG_MAX_MB=2
VAL_LOG_BACKUPS=3

# ─── API Server ───────────────────────────────────────────────────────────
VAL_API_HOST=127.0.0.1
VAL_API_PORT=8765

# ─── Session ──────────────────────────────────────────────────────────────
VAL_SESSION=val-session
VAL_VERSION=9.0.0
VAL_TELEMETRY=false

# ─── Operator Mode ────────────────────────────────────────────────────────
# When true, terminal allowlist is bypassed. Only destructive commands blocked.
OPERATOR_MODE=true
SAFE_MODE=false
POWER_MODE=true

# ─── Resource Targets ────────────────────────────────────────────────────
CPU_USAGE_TARGET=0.75
GPU_USAGE_TARGET=0.80
VAL_MAX_MEMORY_GB=6.0
LOW_RAM_MODE=true

# ─── Tool Timeouts ───────────────────────────────────────────────────────
TOOL_TIMEOUT_DEFAULT=120
TOOL_TIMEOUT_HASHCAT=3600
